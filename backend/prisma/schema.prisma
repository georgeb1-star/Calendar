generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                String               @id @default(cuid())
  name              String               @unique
  color             String               @default("#3B82F6")
  locations         Location[]
  users             User[]
  bookings          Booking[]
  dailyTokens       CompanyDailyTokens[]
  subscription      Subscription?
  recurringBookings RecurringBooking[]
  createdAt         DateTime             @default(now())
}

model Location {
  id                String               @id @default(cuid())
  name              String               @unique
  address           String?
  color             String               @default("#3B82F6")
  isActive          Boolean              @default(true)
  companyId         String
  company           Company              @relation(fields: [companyId], references: [id])
  users             User[]
  rooms             Room[]
  bookings          Booking[]
  dailyTokens       LocationDailyTokens[]
  recurringBookings RecurringBooking[]
  blackoutDates     BlackoutDate[]
  createdAt         DateTime             @default(now())
}

model BlackoutDate {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  date       String   // "YYYY-MM-DD"
  reason     String?
  createdAt  DateTime @default(now())

  @@unique([locationId, date])
}

model LocationDailyTokens {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])
  date        String   // "YYYY-MM-DD"
  tokensTotal Float    @default(3)
  tokensUsed  Float    @default(0)
  createdAt   DateTime @default(now())

  @@unique([locationId, date])
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  passwordHash      String
  name              String
  role              Role            @default(EMPLOYEE)
  status            UserStatus      @default(ACTIVE)
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id])
  locationId        String?
  location          Location?       @relation(fields: [locationId], references: [id])
  bookings          Booking[]
  recurringBookings RecurringBooking[]
  bookingInvites    BookingInvite[]
  createdAt         DateTime        @default(now())
}

enum Role {
  EMPLOYEE
  ADMIN         // deprecated — use OFFICE_ADMIN
  COMPANY_ADMIN
  OFFICE_ADMIN
  GLOBAL_ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
}

enum Plan {
  FREE
  PRO
  MAX
}

model Subscription {
  id                   String    @id @default(cuid())
  companyId            String    @unique
  company              Company   @relation(fields: [companyId], references: [id])
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  plan                 Plan      @default(FREE)
  status               String    @default("active")
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Room {
  id                String             @id @default(cuid())
  name              String
  capacity          Int
  amenities         String[]
  isActive          Boolean            @default(true)
  locationId        String
  location          Location           @relation(fields: [locationId], references: [id])
  bookings          Booking[]
  recurringBookings RecurringBooking[]
  createdAt         DateTime           @default(now())
}

model Booking {
  id             String            @id @default(cuid())
  title          String
  roomId         String
  room           Room              @relation(fields: [roomId], references: [id])
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId      String
  company        Company           @relation(fields: [companyId], references: [id])
  locationId     String
  location       Location          @relation(fields: [locationId], references: [id])
  startTime      DateTime
  endTime        DateTime
  durationHours  Float
  status         BookingStatus     @default(PENDING_APPROVAL)
  checkInTime    DateTime?
  isNoShow       Boolean           @default(false)
  notes          String?
  isPaid         Boolean           @default(false)
  paymentStatus  String?
  tokenCost      Float             @default(0)
  tokensPending  Boolean           @default(false)
  reminderSentAt DateTime?
  recurringId    String?
  recurring      RecurringBooking? @relation(fields: [recurringId], references: [id])
  invites        BookingInvite[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  logs           BookingLog[]

  @@index([roomId, startTime, endTime])
}

enum BookingStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model RecurringBooking {
  id         String    @id @default(cuid())
  userId     String
  companyId  String
  locationId String
  roomId     String
  title      String
  notes      String?
  dayOfWeek  Int       // 1=Mon … 7=Sun (ISO weekday)
  startTime  String    // "HH:MM"
  endTime    String    // "HH:MM"
  endDate    DateTime
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company   @relation(fields: [companyId], references: [id])
  location   Location  @relation(fields: [locationId], references: [id])
  room       Room      @relation(fields: [roomId], references: [id])
  bookings   Booking[]
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model BookingInvite {
  id        String       @id @default(cuid())
  bookingId String
  userId    String
  status    InviteStatus @default(PENDING)
  createdAt DateTime     @default(now())
  booking   Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bookingId, userId])
}

model CompanyDailyTokens {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  date        String   // "YYYY-MM-DD"
  tokensTotal Float    @default(3)
  tokensUsed  Float    @default(0)
  createdAt   DateTime @default(now())

  @@unique([companyId, date])
}

model BookingLog {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  action    String
  actorId   String
  metadata  Json?
  timestamp DateTime @default(now())
}
